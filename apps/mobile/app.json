{
  "expo": {
    "name": "Niha Prototype",
    "slug": "niha-prototype",
    "scheme": "niha",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prototype.niha"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-router"
    ]
  }
}
